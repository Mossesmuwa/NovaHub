{
  "$schema": "https://turbo.build/json-schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env", "**/.env.local"],
  "tasks": {
    "dev": {
      "cache": false,
      "interactive": true,
      "dependsOn": []
    },
    "build": {
      "outputs": [".next/**"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": true,
      "outputs": []
    },
    "type-check": {
      "cache": true,
      "outputs": []
    }
  },
  "globalPassThroughEnv": [
    "NEXT_PUBLIC_*",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "ANTHROPIC_API_KEY",
    "GOOGLE_GENAI_API_KEY",
    "STRIPE_PUBLIC_KEY",
    "STRIPE_SECRET_KEY",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY"
  ]
}
