{
  "$schema": "https://turbo.build/json-schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env", "**/.env.local"],

  "tasks": {
    "dev": {
      "cache": false,
      "interactive": true,
      "dependsOn": []
    },

    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },

    "lint": {
      "outputs": []
    },

    "type-check": {
      "outputs": []
    }
  },

  "globalPassThroughEnv": [
    "NEXT_PUBLIC_*",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "STRIPE_PUBLIC_KEY",
    "STRIPE_SECRET_KEY"
  ]
}
