# Admin App Environment Variables (.env.local)
# Copy to apps/admin/.env.local and fill in values

# Supabase (shared with web app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URLs
# LOCAL DEVELOPMENT
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# For PRODUCTION, Vercel will override with:
# NEXT_PUBLIC_WEB_APP_URL=https://novahub.app
# NEXT_PUBLIC_ADMIN_URL=https://admin.novahub.app
# NEXT_PUBLIC_SITE_URL=https://admin.novahub.app

# Optional: Other APIs
# ANTHROPIC_API_KEY=your-key
# RESEND_API_KEY=your-key

# Start dev server with: npm run dev:admin
